<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.musiclibrary.view.AddToPlaylistController"
      prefWidth="360" spacing="14"
      style="-fx-background-color: white; -fx-padding: 20;">

    <Label fx:id="labelTrack"
           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

    <Label text="Seleziona la playlist di destinazione:"
           style="-fx-text-fill: #555555;"/>

    <ComboBox fx:id="comboPlaylist"
              prefWidth="320" prefHeight="30"/>

    <Label fx:id="labelError"
           style="-fx-text-fill: #cc0000; -fx-font-size: 11px;"
           wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annulla" prefWidth="100"
                onAction="#onCancel"/>
        <Button text="Aggiungi" prefWidth="120"
                onAction="#onAdd"
                style="-fx-background-color: #2C5F8A;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 4;"/>
    </HBox>
</VBox>